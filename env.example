# Database
DATABASE_URL="postgresql://vibe:vibe@localhost:5432/vibe?schema=public"
SHADOW_DATABASE_URL="postgresql://vibe:vibe@localhost:5432/vibe_shadow?schema=public"

# Redis / Jobs
REDIS_URL="redis://localhost:6379"
WORKER_CONCURRENCY="5"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="supabase-service-role"

# Authentication
# IMPORTANT: Generate a secure random string for production (minimum 32 characters)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-secret-jwt-key-must-be-at-least-32-characters-long-replace-this"
JWT_EXPIRY="7d"

# Email Service (choose one)
# Option 1: SMTP (Gmail example - use App Password, not regular password)
# To get Gmail App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-char-app-password-here"
SMTP_FROM="noreply@vibe.app"

# Option 2: SendGrid
# SENDGRID_API_KEY="SG.xxx"

# Option 3: AWS SES
# AWS_SES_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="xxx"
# AWS_SECRET_ACCESS_KEY="xxx"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_FEATURE_ADS="1"

